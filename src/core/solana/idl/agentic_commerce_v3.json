  "types": [
    {
      "name": "AcpState",
      "docs": [
        "Global program configuration. Singleton PDA seeded by `[\"acp_state\"]`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "authority",
            "docs": [
              "Current program authority; can create/remove hook whitelists and update fees."
            ],
            "type": "pubkey"
          },
          {
            "name": "pending_authority",
            "docs": [
              "Nominated successor (two-step transfer). `None` until `nominate_authority` is called."
            ],
            "type": {
              "option": "pubkey"
            }
          },
          {
            "name": "payment_token",
            "docs": [
              "SPL mint accepted for job budgets."
            ],
            "type": "pubkey"
          },
          {
            "name": "platform_treasury",
            "docs": [
              "Wallet that receives platform fees and reclaimed vault rent."
            ],
            "type": "pubkey"
          },
          {
            "name": "platform_fee_bp",
            "docs": [
              "Platform fee in basis points (0-10000). Applied to vault balance on completion."
            ],
            "type": "u64"
          },
          {
            "name": "evaluator_fee_bp",
            "docs": [
              "Evaluator fee in basis points (0-10000). Applied on evaluator-confirmed completions."
            ],
            "type": "u64"
          },
          {
            "name": "job_counter",
            "docs": [
              "Monotonically increasing counter; next job receives this ID."
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed."
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "AuthorityNominated",
      "docs": [
        "Emitted when a new authority is nominated (first step of two-step transfer)."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "current_authority",
            "type": "pubkey"
          },
          {
            "name": "pending_authority",
            "type": "pubkey"
          }
        ]
      }
    },
    {
      "name": "AuthorityTransferred",
      "docs": [
        "Emitted when a pending authority accepts ownership (second step of two-step transfer)."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "old_authority",
            "type": "pubkey"
          },
          {
            "name": "new_authority",
            "type": "pubkey"
          }
        ]
      }
    },
    {
      "name": "BudgetSet",
      "docs": [
        "Emitted when the budget is set on a job via `set_budget`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "amount",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "EvaluatorFeePaid",
      "docs": [
        "Emitted when the evaluator fee is transferred on evaluator-confirmed completion."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "evaluator",
            "type": "pubkey"
          },
          {
            "name": "amount",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "EvaluatorFeeUpdated",
      "docs": [
        "Emitted when the evaluator fee rate is updated."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "fee_bp",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "HookWhitelist",
      "docs": [
        "Whitelist entry for an approved hook program. PDA seeded by `[\"hook_whitelist\", hook]`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "hook",
            "docs": [
              "The whitelisted hook program ID."
            ],
            "type": "pubkey"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed."
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "HookWhitelistUpdated",
      "docs": [
        "Emitted when a hook program is added to or removed from the whitelist."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "hook",
            "type": "pubkey"
          },
          {
            "name": "status",
            "type": "bool"
          }
        ]
      }
    },
    {
      "name": "Job",
      "docs": [
        "A single job. PDA seeded by `[\"job\", client, job_id_le_bytes]`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "docs": [
              "Unique identifier assigned from `AcpState.job_counter` at creation."
            ],
            "type": "u64"
          },
          {
            "name": "client",
            "docs": [
              "The party that created and funds the job."
            ],
            "type": "pubkey"
          },
          {
            "name": "provider",
            "docs": [
              "The agent fulfilling the job. `Pubkey::default()` until set via `set_provider`."
            ],
            "type": "pubkey"
          },
          {
            "name": "evaluator",
            "docs": [
              "The adjudicator who completes or rejects. `Pubkey::default()` enables auto-complete on submit."
            ],
            "type": "pubkey"
          },
          {
            "name": "state",
            "docs": [
              "Current lifecycle state (see `JobState`)."
            ],
            "type": {
              "defined": {
                "name": "JobState"
              }
            }
          },
          {
            "name": "budget_amount",
            "docs": [
              "Token amount escrowed on fund. Zero for zero-budget jobs."
            ],
            "type": "u64"
          },
          {
            "name": "budget_mint",
            "docs": [
              "SPL mint for the budget. `None` until `set_budget` is called."
            ],
            "type": {
              "option": "pubkey"
            }
          },
          {
            "name": "description",
            "docs": [
              "Human-readable description (max 256 bytes)."
            ],
            "type": "string"
          },
          {
            "name": "expired_at",
            "docs": [
              "Unix timestamp after which the job may be claimed as expired."
            ],
            "type": "i64"
          },
          {
            "name": "created_at",
            "docs": [
              "Unix timestamp of job creation."
            ],
            "type": "i64"
          },
          {
            "name": "hook_address",
            "docs": [
              "Optional hook program invoked on before/after action callbacks."
            ],
            "type": {
              "option": "pubkey"
            }
          },
          {
            "name": "deliverable",
            "docs": [
              "32-byte hash/identifier of the work product, set on submit."
            ],
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "completion_reason",
            "docs": [
              "32-byte completion or rejection reason, set on complete/reject."
            ],
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "vault_bump",
            "docs": [
              "PDA bump for the per-job vault authority. Set during fund."
            ],
            "type": "u8"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed for this job account."
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "JobCompleted",
      "docs": [
        "Emitted when a job is completed (evaluator approval or auto-complete)."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "evaluator",
            "type": "pubkey"
          },
          {
            "name": "reason",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          }
        ]
      }
    },
    {
      "name": "JobCreated",
      "docs": [
        "Emitted when a new job is created via `create_job`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "client",
            "type": "pubkey"
          },
          {
            "name": "provider",
            "type": "pubkey"
          },
          {
            "name": "evaluator",
            "type": "pubkey"
          },
          {
            "name": "expired_at",
            "type": "i64"
          },
          {
            "name": "hook",
            "type": "pubkey"
          }
        ]
      }
    },
    {
      "name": "JobExpired",
      "docs": [
        "Emitted when an expired job is claimed via `claim_refund`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "JobFunded",
      "docs": [
        "Emitted when a client funds a job, escrowing tokens in the vault."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "client",
            "type": "pubkey"
          },
          {
            "name": "amount",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "JobRejected",
      "docs": [
        "Emitted when a job is rejected by an evaluator, client, or provider."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "rejector",
            "type": "pubkey"
          },
          {
            "name": "reason",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          }
        ]
      }
    },
    {
      "name": "JobState",
      "docs": [
        "Job lifecycle states. Two valid paths exist (L-15):",
        "Funded path:      Open -> Funded -> Submitted -> Completed | Rejected | Expired",
        "Zero-budget path: Open -> Submitted -> Completed | Rejected  (budget_amount == 0)",
        "Open jobs can also be Rejected directly by client or provider."
      ],
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Open"
          },
          {
            "name": "Funded"
          },
          {
            "name": "Submitted"
          },
          {
            "name": "Completed"
          },
          {
            "name": "Rejected"
          },
          {
            "name": "Expired"
          }
        ]
      }
    },
    {
      "name": "JobSubmitted",
      "docs": [
        "Emitted when a provider submits a deliverable."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "provider",
            "type": "pubkey"
          },
          {
            "name": "deliverable",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          }
        ]
      }
    },
    {
      "name": "PaymentReleased",
      "docs": [
        "Emitted when the net payment is transferred to the provider on completion."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "provider",
            "type": "pubkey"
          },
          {
            "name": "amount",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "PlatformFeeUpdated",
      "docs": [
        "Emitted when the platform fee rate or treasury address is updated."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "fee_bp",
            "type": "u64"
          },
          {
            "name": "treasury",
            "type": "pubkey"
          }
        ]
      }
    },
    {
      "name": "ProviderSet",
      "docs": [
        "Emitted when a provider is assigned to a job via `set_provider`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "provider",
            "type": "pubkey"
          }
        ]
      }
    },
    {
      "name": "Refunded",
      "docs": [
        "Emitted when escrowed tokens are returned to the client (rejection or expiry)."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "client",
            "type": "pubkey"
          },
          {
            "name": "amount",
            "type": "u64"
          }
        ]
      }
    }
  ]
}