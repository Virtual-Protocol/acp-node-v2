    "version": "0.1.0"
  },
  "types": [
    {
      "name": "AuthorityNominated",
      "type": {
        "fields": [
          {
            "name": "current_authority",
            "type": "pubkey"
          },
          {
            "name": "pending_authority",
            "type": "pubkey"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "name": "AuthorityTransferred",
      "type": {
        "fields": [
          {
            "name": "old_authority",
            "type": "pubkey"
          },
          {
            "name": "new_authority",
            "type": "pubkey"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Cached required-selectors bitmask for one configured sub-hook. Populated",
        "from the sub-hook's `HookMetadata` PDA at mutation time so that",
        "`validate_completeness` and fund-time re-validation can run from",
        "HookRouter alone (no metadata account reads needed at fan-out)."
      ],
      "name": "CachedHookMetadata",
      "type": {
        "fields": [
          {
            "name": "hook",
            "type": "pubkey"
          },
          {
            "name": "required_selectors",
            "type": "u8"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Emitted in `before_action`/`after_action` when a configured sub-hook is",
        "no longer whitelisted on ACP at fan-out time. The router skips the",
        "dewhitelisted hook and continues to the next one. Mirrors EVM",
        "`DewhitelistedHookSkipped`."
      ],
      "name": "DewhitelistedHookSkipped",
      "type": {
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "action",
            "type": "u8"
          },
          {
            "name": "hook",
            "type": "pubkey"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "name": "HookAdded",
      "type": {
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "action",
            "type": "u8"
          },
          {
            "name": "hook",
            "type": "pubkey"
          },
          {
            "name": "position",
            "type": "u8"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Hook self-declaration. Read by other multi-hook-routers if this router",
        "is ever nested as a sub-hook (defensive: also lets external indexers",
        "query \"what does multi-hook-router forward?\"). PDA seeded by `[b\"hook_metadata\"]`."
      ],
      "name": "HookMetadata",
      "type": {
        "fields": [
          {
            "name": "required_selectors",
            "type": "u8"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "name": "HookRemoved",
      "type": {
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "action",
            "type": "u8"
          },
          {
            "name": "hook",
            "type": "pubkey"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Per-job hook configuration. Five per-selector ordered lists, one per",
        "hookable lifecycle action. PDA seeded by `[\"hook_router\", job_id_le_bytes]`.",
        "",
        "Mirrors EVM `mapping(jobId => mapping(selector => address[]))` — the same",
        "hook can appear in multiple selector lists; lists are independent."
      ],
      "name": "HookRouter",
      "type": {
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "set_budget_hooks",
            "type": {
              "vec": "pubkey"
            }
          },
          {
            "name": "fund_hooks",
            "type": {
              "vec": "pubkey"
            }
          },
          {
            "name": "submit_hooks",
            "type": {
              "vec": "pubkey"
            }
          },
          {
            "name": "complete_hooks",
            "type": {
              "vec": "pubkey"
            }
          },
          {
            "name": "reject_hooks",
            "type": {
              "vec": "pubkey"
            }
          },
          {
            "docs": [
              "Cached metadata for unique configured sub-hooks. Used by",
              "`validate_completeness` and fund-time re-validation."
            ],
            "name": "hook_metadata_cache",
            "type": {
              "vec": {
                "defined": {
                  "name": "CachedHookMetadata"
                }
              }
            }
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "name": "HooksConfigured",
      "type": {
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "action",
            "type": "u8"
          },
          {
            "name": "hooks",
            "type": {
              "vec": "pubkey"
            }
          }
        ],
        "kind": "struct"
      }
    },
    {
      "name": "HooksReordered",
      "type": {
        "fields": [
          {
            "name": "job_id",
            "type": "u64"
          },
          {
            "name": "action",
            "type": "u8"
          },
          {
            "name": "hooks",
            "type": {
              "vec": "pubkey"
            }
          }
        ],
        "kind": "struct"
      }
    },
    {
      "name": "MaxHooksPerJobUpdated",
      "type": {
        "fields": [
          {
            "name": "old_max",
            "type": "u8"
          },
          {
            "name": "new_max",
            "type": "u8"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Global router configuration. Singleton PDA seeded by `[\"router_state\"]`."
      ],
      "name": "RouterState",
      "type": {
        "fields": [
          {
            "name": "acp_program",
            "type": "pubkey"
          },
          {
            "name": "authority",
            "type": "pubkey"
          },
          {
            "name": "pending_authority",
            "type": {
              "option": "pubkey"
            }
          },
          {
            "docs": [
              "Admin-configurable max sub-hooks per job, per selector. Range: 1..=255.",
              "No logical upper bound (mirrors EVM `MultiHookRouter.maxHooksPerJob`).",
              "Practical limit governed by Solana tx-size at runtime (~5-8 hooks per",
              "call without Address Lookup Tables)."
            ],
            "name": "max_hooks_per_job",
            "type": "u8"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ],
        "kind": "struct"
      }
    }
  ]
}
