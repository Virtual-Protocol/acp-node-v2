  "types": [
    {
      "docs": [
        "Hook self-declaration of which selectors this hook implements. Read by",
        "multi-hook-router's `_validate_selector_completeness` (mirrors EVM",
        "`IACPHookMetadata.requiredSelectors()`). PDA seeded by `[b\"hook_metadata\"]`.",
        "",
        "Bitmask layout: bit 0 = SetBudget, 1 = Fund, 2 = Submit, 3 = Complete, 4 = Reject."
      ],
      "name": "HookMetadata",
      "type": {
        "fields": [
          {
            "name": "required_selectors",
