  "metadata": {
    "description": "Subscription State - shared subscription storage for ACP hooks",
    "name": "subscription_state",
    "spec": "0.1.0",
    "version": "0.1.0"
  },
  "types": [
    {
      "docs": [
        "Emitted when a new authority is nominated (first step of two-step transfer)."
      ],
      "name": "AuthorityNominated",
      "type": {
        "fields": [
          {
            "name": "current_authority",
            "type": "pubkey"
          },
          {
            "name": "pending_authority",
            "type": "pubkey"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Emitted when a pending authority accepts ownership (second step of two-step transfer)."
      ],
      "name": "AuthorityTransferred",
      "type": {
        "fields": [
          {
            "name": "old_authority",
            "type": "pubkey"
          },
          {
            "name": "new_authority",
            "type": "pubkey"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Global state -- stores admin authority. Singleton PDA seeded by `[\"state_config\"]`."
      ],
      "name": "StateConfig",
      "type": {
        "fields": [
          {
            "docs": [
              "Current program authority; can add/remove writers and transfer ownership."
            ],
            "name": "authority",
            "type": "pubkey"
          },
          {
            "docs": [
              "Nominated successor (two-step transfer). `None` until `nominate_authority` is called."
            ],
            "name": "pending_authority",
            "type": {
              "option": "pubkey"
            }
          },
          {
            "docs": [
              "PDA bump seed."
            ],
            "name": "bump",
            "type": "u8"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Emitted when a subscription is activated or extended by a writer via CPI."
      ],
      "name": "SubscriptionActivated",
      "type": {
        "fields": [
          {
            "name": "client",
            "type": "pubkey"
          },
          {
            "name": "provider",
            "type": "pubkey"
          },
          {
            "name": "package_id",
            "type": "u64"
          },
          {
            "name": "expiry",
            "type": "i64"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Subscription expiry per client/provider/package.",
        "Seeds: [\"sub_expiry\", client, provider, package_id]"
      ],
      "name": "SubscriptionExpiry",
      "type": {
        "fields": [
          {
            "docs": [
              "The subscribing client."
            ],
            "name": "client",
            "type": "pubkey"
          },
          {
            "docs": [
              "The service provider."
            ],
            "name": "provider",
            "type": "pubkey"
          },
          {
            "docs": [
              "Identifies which subscription package this tracks."
            ],
            "name": "package_id",
            "type": "u64"
          },
          {
            "docs": [
              "Unix timestamp when this subscription expires. Monotonically increasing."
            ],
            "name": "expiry",
            "type": "i64"
          },
          {
            "docs": [
              "PDA bump seed."
            ],
            "name": "bump",
            "type": "u8"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Emitted when a program is granted the writer role (or re-activated)."
      ],
      "name": "WriterAdded",
      "type": {
        "fields": [
          {
            "name": "writer",
            "type": "pubkey"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Writer registry — tracks authorized programs that can write subscription data.",
        "Equivalent to Solidity's WRITER_ROLE in AccessControl.",
        "Seeds: [\"writer\", writer_pubkey]",
        "",
        "`is_active` mirrors EVM's revokeRole semantics: the PDA is never closed so",
        "in-flight subscription jobs (whose fund step has not yet fired) can still",
        "observe the deactivation and abort cleanly (F-34)."
      ],
      "name": "WriterRegistry",
      "type": {
        "fields": [
          {
            "docs": [
              "The authorized program ID."
            ],
            "name": "writer",
            "type": "pubkey"
          },
          {
            "docs": [
              "Whether this writer is currently active. Deactivated writers are kept alive (F-34)."
            ],
            "name": "is_active",
            "type": "bool"
          },
          {
            "docs": [
              "PDA bump seed."
            ],
            "name": "bump",
            "type": "u8"
          }
        ],
        "kind": "struct"
      }
    },
    {
      "docs": [
        "Emitted when a writer's role is revoked (deactivated, PDA kept alive)."
      ],
      "name": "WriterRemoved",
      "type": {
        "fields": [
          {
            "name": "writer",
            "type": "pubkey"
          }
        ],
        "kind": "struct"
      }
    }
  ]
}
